# =============================================================================
# AgentVault - THE ONLY ENV FILE (for the entire project)
# =============================================================================
# Copy to .env and fill in:
#   cp .env.example .env
#
# Backend reads this directly via python-dotenv.
# Contracts load it via dotenv-cli:  npm run deploy:sepolia
# Frontend reads from backend's GET /config endpoint (no .env.local needed).
#
# NEVER commit .env to git. NEVER share its contents.
# =============================================================================

# --- NETWORK (Mantle Sepolia) ---
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5000
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_TESTNET_CHAIN_ID=5003
MANTLESCAN_API_URL=https://api-sepolia.mantlescan.xyz/api
MANTLESCAN_BROWSER_URL=https://sepolia.mantlescan.xyz

# --- WALLET (hackathon-only wallet, fund from faucet) ---
PRIVATE_KEY=
DEPLOYER_ADDRESS=

# --- GAS ---
GAS_PRICE=1000000000
GAS_LIMIT=8000000

# --- MANTLESCAN (optional, for verify only) ---
MANTLESCAN_API_KEY=

# --- CONTRACT ADDRESSES (empty until deploy, then fill in) ---
VAULT_ADDRESS=
STRATEGY_MANAGER_ADDRESS=
AGENT_IDENTITY_ADDRESS=
AGENT_TOKEN_ID=
USDC_ADDRESS=
WETH_ADDRESS=

# --- BACKEND WALLET (for signing on-chain txs, same key as PRIVATE_KEY) ---
WALLET_PRIVATE_KEY=

# --- AI INTEGRATIONS (ELFA & BYREAL) ---
ELFA_AI_API_KEY=
BYREAL_API_KEY=

# --- CORS (comma-separated) ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- RATE LIMITING ---
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_PERIOD=60

# --- DATABASE (optional, MVP works without it) ---
DATABASE_URL=

# --- MISC ---
ENVIRONMENT=development
UVICORN_WORKERS=1
UVICORN_RELOAD=true

# --- FRONTEND CONFIG (read by backend GET /config, passed to frontend) ---
FRONTEND_WALLETCONNECT_PROJECT_ID=
FRONTEND_BACKEND_API_URL=http://localhost:8000
